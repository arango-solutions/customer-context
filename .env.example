# Live ArangoDB connection for the Phase 1 capability probe (ARCH-03).
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# The probe user needs create/drop on a SCRATCH database (it makes then drops a
# throwaway collection + HNSW vector index + ArangoSearch BM25 view). Not a
# read-only user, and not a production-write user.

ARANGO_ENDPOINT=https://<host>:8529
ARANGO_DATABASE=<database-name>
ARANGO_USER=<scratch-db-user>
ARANGO_PASSWORD=<password-or-jwt>

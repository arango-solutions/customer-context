# Live ArangoDB connection + model key for the Customer 360 agent.
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
#
# The agent reads two graphs (read-only AQL). The Wave-0 view DDL needs a JWT
# (obtained via POST /_open/auth), which the same ARANGO_* creds produce.

ARANGO_ENDPOINT=https://<host>:8529
ARANGO_DATABASE=<database-name>
ARANGO_USERNAME=<db-user>
ARANGO_PASSWORD=<password>

# Model key for the planner/answerer + query embeddings (D-06: v1 is OpenAI-only;
# no ANTHROPIC_API_KEY needed for v1 — Anthropic is a one-line provider swap later).
OPENAI_API_KEY=

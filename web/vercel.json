{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix ..",
  "functions": {
    "app/api/ask/route.ts": {
      "maxDuration": 60
    },
    "app/api/canary/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/canary",
      "schedule": "0 0 * * *"
    }
  ]
}

{
  "name": "customer360-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Customer 360 reasoning agent — ToolLoopAgent + curated AQL specialists over a dual-graph ArangoDB backend (Phase 5).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stream": {
      "types": "./dist/stream.d.ts",
      "default": "./dist/stream.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "ask": "tsx cli.ts"
  },
  "dependencies": {
    "ai": "6.0.208",
    "@ai-sdk/openai": "3.0.73",
    "@ai-sdk/provider": "3.0.10",
    "arangojs": "10.3.1",
    "zod": "4.4.3",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "tsx": "4.22.4",
    "vitest": "4.1.9",
    "@types/node": "^24.0.0"
  }
}
